#!/usr/bin/env bash

# ==========================================
# Configuration
# ==========================================
IMAGE_NAME="pic:latest"
AGENT_CONFIG_DIR="${HOME}/.config/pi-agent"
# Generate a unique container name based on the current directory
PROJECT_SLUG="$(basename "$PWD" | tr -cd '[:alnum:]_')"
CONTAINER_NAME="pic_${PROJECT_SLUG}"
CONTAINER_WORKDIR="/wd/${PROJECT_SLUG}"

# Ensure host config directory exists
mkdir -p "$AGENT_CONFIG_DIR"

# ==========================================
# Run
# ==========================================
echo "Starting Podman container: ${CONTAINER_NAME}..."
echo "Mounting $PWD to ${CONTAINER_WORKDIR}..."

podman run -it --rm \
    --name "$CONTAINER_NAME" \
    -v "$PWD:${CONTAINER_WORKDIR}:Z" \
    -v "$AGENT_CONFIG_DIR:/root/.pi:Z" \
    -w "${CONTAINER_WORKDIR}" \
    "$IMAGE_NAME" pi "$@"
